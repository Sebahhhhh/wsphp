# GET
curl -X GET http://localhost/wsphp/index.php -H "Accept: application/json"

# POST JSON
curl -X POST http://localhost/wsphp/index.php -H "Content-Type: application/json" -H "Accept: application/json" -d "{\"nome\":\"prova\",\"valore\":100}"

# POST XML
curl -X POST http://localhost/wsphp/index.php -H "Content-Type: application/xml" -H "Accept: application/xml" -d "<?xml version=\"1.0\"?><root><nome>prova</nome><valore>100</valore></root>"

# PUT JSON
curl -X PUT http://localhost/wsphp/index.php -H "Content-Type: application/json" -H "Accept: application/json" -d "{\"nome\":\"aggiornato\",\"valore\":50}"

# DELETE JSON
curl -X DELETE http://localhost/wsphp/index.php -H "Content-Type: application/json" -H "Accept: application/json" -d "{\"nome\":\"cancella\",\"valore\":999}"
